def services = [
    [name: 'apigateways',   dockerfile: 'src/ApiGateways/OcelotApiGateway/Dockerfile',     image: 'ocelot-api-gateway', valuesKey: 'apigateways'],
    [name: 'account',       dockerfile: 'src/Services/Account/Account.API/Dockerfile',      image: 'account-api',        valuesKey: 'account'],
    [name: 'customer-grpc', dockerfile: 'src/Services/Customer/Customer.GRPC/Dockerfile',  image: 'customer-grpc',      valuesKey: 'customerGrpc'],
    [name: 'customer-api',  dockerfile: 'src/Services/Customer/Customer.API/Dockerfile',   image: 'customer-api',       valuesKey: 'customerApi'],
    [name: 'transaction',   dockerfile: 'src/Services/Transaction/Transaction.API/Dockerfile', image: 'transaction-api', valuesKey: 'transaction'],
    [name: 'webstatus',     dockerfile: 'src/WebApps/WebStatus/Dockerfile',                image: 'webstatus-ui',       valuesKey: 'webstatus']
]

pipeline {
    agent {
        kubernetes {
            label 'dotnet-kaniko-agent'
            defaultContainer 'tools'
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
    - name: tools
      image: alpine:3.20
      command:
        - cat
      tty: true

    - name: dotnet
      image: mcr.microsoft.com/dotnet/sdk:8.0
      command:
        - cat
      tty: true

    - name: awscli
      image: public.ecr.aws/aws-cli/aws-cli:latest
      command:
        - cat
      tty: true

    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command:
        - /busybox/cat
      tty: true

    - name: jnlp
      image: jenkins/inbound-agent:jdk21
'''
        }
    }

    environment {
        AWS_REGION = 'eu-north-1'
        AWS_ACCOUNT_ID = '007079198698'
        ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

        AWS_CREDENTIALS_ID = 'aws-prod-credentials'
        GITOPS_SSH_CREDENTIALS_ID = 'gitops-ssh-key'

        GITOPS_REPO = 'git@github.com:your-org/my-api.git'
        GITOPS_BRANCH = 'main'
    }

    stages {
        stage('Install Tools') {
            steps {
                container('tools') {
                    sh '''
                        apk add --no-cache git openssh-client yq
                        git --version
                        yq --version
                    '''
                }
            }
        }

        stage('Checkout Application Repo') {
    steps {
        container('tools') {
            checkout scm

            sh '''
                git config --global --add safe.directory "$WORKSPACE"
                git status
            '''

            script {
                def shortCommit = sh(
                    script: 'git rev-parse --short=8 HEAD',
                    returnStdout: true
                ).trim()

                env.IMAGE_TAG = "${env.BUILD_NUMBER}-${shortCommit}"
                echo "IMAGE_TAG = ${env.IMAGE_TAG}"
            }
            
            // Debug: Print directory structure and find Dockerfiles
            sh '''
                echo "========================================="
                echo "=== Current Working Directory ==="
                pwd
                echo ""
                
                echo "=== Workspace Directory Contents ==="
                ls -la /home/jenkins/agent/workspace/SampleBank/
                echo ""
                
                echo "=== SRC Directory Structure (3 levels) ==="
                find /home/jenkins/agent/workspace/SampleBank/src -maxdepth 3 -type d 2>/dev/null || echo "src directory not found"
                echo ""
                
                echo "=== ALL Dockerfiles Found ==="
                find /home/jenkins/agent/workspace/SampleBank -name "Dockerfile" -o -name "dockerfile" 2>/dev/null
                echo ""
                
                echo "=== Detailed listing of each Dockerfile ==="
                for dockerfile in $(find /home/jenkins/agent/workspace/SampleBank -name "Dockerfile" -o -name "dockerfile" 2>/dev/null); do
                    echo "----------------------------------------"
                    echo "Dockerfile: $dockerfile"
                    echo "Directory: $(dirname $dockerfile)"
                    ls -la $(dirname $dockerfile)
                    echo ""
                done
                
                echo "========================================="
            '''
        }
    }
}

        stage('Restore and Build .NET Projects') {
            steps {
                container('dotnet') {
                    sh '''
                        dotnet --info

                        for project in $(find src -name "*.csproj"); do
                            echo "Restoring $project"
                            dotnet restore "$project"

                            echo "Building $project"
                            dotnet build "$project" --configuration Release --no-restore
                        done
                    '''
                }
            }
        }

stage('Debug AWS Credentials') {
    steps {
        container('awscli') {
            withCredentials([[
                $class: 'AmazonWebServicesCredentialsBinding',
                credentialsId: "${AWS_CREDENTIALS_ID}"
            ]]) {
                sh """
                    echo "Testing AWS credentials..."
                    echo "AWS_ACCESS_KEY_ID length: \${#AWS_ACCESS_KEY_ID}"
                    echo "AWS_SECRET_ACCESS_KEY length: \${#AWS_SECRET_ACCESS_KEY}"
                    aws sts get-caller-identity --region ${AWS_REGION}
                """
            }
        }
    }
}

        stage('Ensure ECR Repositories Exist') {
            steps {
                container('awscli') {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: "${AWS_CREDENTIALS_ID}"
                    ]]) {
                        script {
                            services.each { svc ->
                                sh """
                                    aws ecr describe-repositories \
                                      --repository-names ${svc.image} \
                                      --region ${AWS_REGION} \
                                    || aws ecr create-repository \
                                      --repository-name ${svc.image} \
                                      --region ${AWS_REGION}
                                """
                            }
                        }
                    }
                }
            }
        }
        stage('Clean Workspace Before Kaniko') {
    steps {
        container('tools') {
            sh '''
                find . -type d \\( -name bin -o -name obj \\) -prune -exec rm -rf {} +
                du -sh .
            '''
        }
    }
}

stage('Build and Push Docker Images with Kaniko') {
    steps {
        script {
            services.each { svc ->
                echo "Building and pushing ${svc.name}"

                podTemplate(
                    label: "kaniko-${svc.name}-${env.BUILD_NUMBER}",
                    yaml: """
apiVersion: v1
kind: Pod
spec:
  containers:
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command:
        - /busybox/cat
      tty: true
    - name: jnlp
      image: jenkins/inbound-agent:jdk21
"""
                ) {
                    node("kaniko-${svc.name}-${env.BUILD_NUMBER}") {
                        checkout scm

                        container(name: 'kaniko', shell: '/busybox/sh') {
                            withCredentials([[
                                $class: 'AmazonWebServicesCredentialsBinding',
                                credentialsId: "${AWS_CREDENTIALS_ID}"
                            ]]) {
                                sh """#!/busybox/sh
set -eux

/kaniko/executor \\
  --context "${WORKSPACE}" \\
  --dockerfile "${WORKSPACE}/${svc.dockerfile}" \\
  --destination "${ECR_REGISTRY}/${svc.image}:${IMAGE_TAG}" \\
  --snapshot-mode=redo \\
  --ignore-path=/product_uuid
"""
                            }
                        }
                    }
                }
            }
        }
    }
}

        stage('Update Helm values.yaml in GitOps Repo') {
            steps {
                container('tools') {
                    sshagent([env.GITOPS_SSH_CREDENTIALS_ID]) {
                        script {
                            sh '''
                                rm -rf gitops-repo

                                mkdir -p ~/.ssh
                                ssh-keyscan github.com >> ~/.ssh/known_hosts

                                git clone --branch "$GITOPS_BRANCH" "$GITOPS_REPO" gitops-repo
                            '''

                            services.each { svc ->
                                sh """
                                    yq -i '.services.${svc.valuesKey}.image.repository = "${ECR_REGISTRY}/${svc.image}"' gitops-repo/charts/values.yaml
                                    yq -i '.services.${svc.valuesKey}.image.tag = "${IMAGE_TAG}"' gitops-repo/charts/values.yaml
                                """
                            }

                            sh '''
                                cd gitops-repo

                                git config user.email "jenkins@yourcompany.com"
                                git config user.name "jenkins-ci"

                                git add charts/values.yaml

                                if git diff --cached --quiet; then
                                    echo "No changes to commit"
                                else
                                    git commit -m "Update images for build ${IMAGE_TAG}"
                                    git push origin "$GITOPS_BRANCH"
                                fi
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo "All services built, pushed to ECR, and Helm values.yaml updated. ArgoCD can now sync."
        }

        failure {
            echo "Build failed."
        }
    }
}